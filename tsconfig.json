{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@zonite/shared": ["../../packages/shared/src/index.ts"],
      "@zonite/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
